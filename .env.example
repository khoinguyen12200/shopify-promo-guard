# Dev Postgres (localhost docker-compose):
DATABASE_URL=postgresql://promo:promo@localhost:5434/promo_guard
DIRECT_DATABASE_URL=postgresql://promo:promo@localhost:5434/promo_guard

# Shopify app credentials (Partner Dashboard → App → Client ID / secret):
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:3000
SCOPES=read_orders,write_orders,read_customers,read_discounts,write_discounts,read_products,write_app_data_metafields

# Secrets — generate with `openssl rand -hex 32`:
APP_KEK_HEX=
SESSION_SECRET=
MAGIC_LINK_SECRET=

# Comma-separated list of platform-admin emails:
PLATFORM_ADMIN_ALLOWED_EMAILS=

# Optional worker tuning (ms between job polls):
# POLL_INTERVAL_MS=2000

# Optional: set DEBUG_GQL=1 to log Admin GraphQL query-cost extensions:
# DEBUG_GQL=1

# Optional dev-only custom shop domain:
# SHOP_CUSTOM_DOMAIN=

# Optional, defaults to development:
NODE_ENV=development
