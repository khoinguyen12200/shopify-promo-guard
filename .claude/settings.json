{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "shopify-plugin@shopify-ai-toolkit": true
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(make verify)",
      "Bash(make test)",
      "Bash(make build)",
      "Bash(make lint)",
      "Bash(make typecheck)",
      "Bash(make functions-schema)",
      "Bash(make db-status)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(npm test)",
      "Bash(npx tsc *)",
      "Bash(npx prisma generate)",
      "Bash(cargo test *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo build *)",
      "Bash(cargo fmt *)",
      "Bash(shopify app function schema *)",
      "Bash(shopify app function run *)",
      "Bash(docker ps)",
      "Bash(docker-compose ps)",
      "Bash(docker-compose logs *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./.shopify/*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(make dev)",
      "Bash(make setup)",
      "Bash(make db-reset)",
      "Bash(make clean)",
      "Bash(npx prisma migrate *)",
      "Bash(docker-compose up *)",
      "Bash(docker-compose down *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update --skip-flows",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
